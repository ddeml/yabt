{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/yabt/backup-root.schema.json",
  "title": "YABT backup root",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "documentType": {
      "type": "string",
      "const": "yabt.backupRoot"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "rootRole": {
      "type": "string",
      "enum": ["source", "target"]
    },
    "archiveId": {
      "type": "string"
    },
    "name": {
      "type": ["string", "null"]
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "livePrefix": {
          "type": "string",
          "minLength": 1
        },
        "histPrefix": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["livePrefix", "histPrefix"]
    },
    "stores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "credentialRef": {
            "type": ["string", "null"]
          }
        },
        "required": ["id", "kind"]
      }
    }
  },
  "required": [
    "documentType",
    "schemaVersion",
    "archiveId",
    "createdAtUtc",
    "layout",
    "stores"
  ]
}
