{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/yabt/yabt-policy.schema.json",
  "title": "YABT folder policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "minLength": 1
    },
    "includePatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "excludePatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "options": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "required": ["format"]
}
